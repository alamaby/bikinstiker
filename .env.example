# =============================================================================
# BikinStiker — root-level environment sample
# =============================================================================
# This file documents every secret/env var the project uses across:
#   1. Supabase Edge Function (`generate-sticker`)
#   2. Local `supabase functions serve` runs
#   3. CI / deployment scripts
#
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# NEVER commit the populated file. `.env*` is gitignored.
# =============================================================================


# -----------------------------------------------------------------------------
# Supabase project — used by `supabase` CLI and the edge function runtime
# -----------------------------------------------------------------------------
# Find these in Supabase Studio → Project Settings → API.
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...

# Used by `supabase link` / `supabase db push`.
SUPABASE_PROJECT_REF=YOUR-PROJECT-REF


# -----------------------------------------------------------------------------
# OpenRouter — server-side ONLY. NEVER ship this to the Flutter client.
# -----------------------------------------------------------------------------
# Create a key at https://openrouter.ai/keys with access to
# the model `sourceful/riverflow-v2-fast`.
OPENROUTER_API_KEY=sk-or-v1-...your-openrouter-key...


# -----------------------------------------------------------------------------
# Optional: identifying headers OpenRouter shows in your dashboard.
# Already hard-coded in the edge function but can be overridden here if needed.
# -----------------------------------------------------------------------------
# OPENROUTER_HTTP_REFERER=https://bikinstiker.app
# OPENROUTER_X_TITLE=BikinStiker


# =============================================================================
# How to push these to Supabase
# =============================================================================
#   supabase secrets set OPENROUTER_API_KEY="$OPENROUTER_API_KEY"
#
# SUPABASE_URL, SUPABASE_ANON_KEY, and SUPABASE_SERVICE_ROLE_KEY are auto-
# injected into every deployed edge function — you do NOT need to `secrets set`
# those.
# =============================================================================
