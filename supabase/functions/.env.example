# =============================================================================
# Edge function local-dev env sample
# =============================================================================
# Used ONLY by `supabase functions serve --env-file ./supabase/functions/.env`.
# In production these are managed by `supabase secrets set ...` and the
# SUPABASE_* trio is auto-injected by the platform.
#
# Copy to `supabase/functions/.env` (gitignored) and fill in real values.
# =============================================================================

# Required by the OpenRouter call in `generate-sticker/index.ts`.
OPENROUTER_API_KEY=sk-or-v1-...your-openrouter-key...

# Supabase platform variables — required when running locally because the
# auto-injection only happens in deployed functions.
SUPABASE_URL=http://host.docker.internal:54321
SUPABASE_ANON_KEY=eyJhbGciOi...local-anon-key-from-`supabase start`...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...local-service-role-key-from-`supabase start`...
